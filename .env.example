# Waypoint — Environment Configuration
# Copy to .env and fill in values. Never commit .env.

# ── Theme selection ──────────────────────────────────────────────────────────
# Which theme to run against: visioncruise | cll | century-cyprus
THEME=visioncruise

# Target environment — overrides the theme's default baseUrl.
# Leave unset to use the URL defined in config/themes/<theme>.ts.
BASE_URL=https://cruise.centurycyprus.com/

# Per-theme base URLs (used by per-theme CI workflows via GitHub Actions variables)
# VISIONCRUISE_BASE_URL=https://www.visioncruise.co.uk
# CLL_BASE_URL=https://cll.dev.digitaltravel.network
# CENTURY_CYPRUS_BASE_URL=https://cruise.centurycyprus.com

# ── Auth ─────────────────────────────────────────────────────────────────────
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=changeme

# ── Payment ──────────────────────────────────────────────────────────────────
# Payment provider used by the site: stripe | worldpay | braintree
PAYMENT_PROVIDER=stripe

# ── CI flags ─────────────────────────────────────────────────────────────────
# Set to 'true' in CI — enables retries, GitHub reporter, 4 workers.
# Leave unset (or omit this line) locally. Do NOT set CI=false — the string
# "false" is truthy in JS and would accidentally enable CI mode.
# CI=true

# Headless mode (true recommended for CI)
HEADLESS=true
