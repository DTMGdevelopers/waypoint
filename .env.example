# Waypoint — Environment Configuration
# Copy to .env and fill in values. Never commit .env.

# Target environment
BASE_URL=https://cruise.centurycyprus.com/

# Auth credentials for tests that require login
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=changeme

# Payment provider used by the site: stripe | worldpay | braintree
PAYMENT_PROVIDER=stripe

# Set to 'true' in CI — enables retries, GitHub reporter, 4 workers.
# Leave unset (or omit this line) locally. Do NOT set CI=false — the string
# "false" is truthy in JS and would accidentally enable CI mode.
# CI=true

# Headless mode (true recommended for CI)
HEADLESS=true

# Base path for the search/results page. Append startdate= and enddate= here.
# Default: /search/
# CLL (Cruise Line Latvia): /lv/meklesana/?traveltype=ocean
SEARCH_PATH=/search/

# Direct paths for the standalone cruise-detail and occupancy step tests.
# Override per-site in GitHub Actions Variables; defaults match century-cypress.
# TEST_CRUISE_PATH=/cruises/2147919/spain-and-france/
# TEST_OCCUPANCY_PATH=/book-a-cruise/2147919/occupancy/?occupancy=2-0-0-0-0
